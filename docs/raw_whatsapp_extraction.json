sender":"5514997877554","ts":"2026-06-22T20:49:59Z","ts_label":"22/06 17:49","meta_prefix":"[22/06 17:49 ~5514997877554]"},{"kind":"text","text":"https://drive.google.com/drive/folders/1rGy3F3q45aJCY6ipDTYyf3Ir88ykjzDm","sender":"5514997877554","ts":"2026-06-22T20:50:39Z","ts_label":"22/06 17:50","meta_prefix":"[22/06 17:50 ~5514997877554]"},{"kind":"text","text":"E os elementos esses;","sender":"5514997877554","ts":"2026-06-22T20:50:52Z","ts_label":"22/06 17:50","meta_prefix":"[22/06 17:50 ~5514997877554]"},{"kind":"text","text":"https://drive.google.com/drive/folders/14JIk5aj_8C5UyLlSfXAaBlrUbPD0J6Hd","sender":"5514997877554","ts":"2026-06-22T20:51:13Z","ts_label":"22/06 17:51","meta_prefix":"[22/06 17:51 ~5514997877554]"},{"kind":"text","text":"Ele funciona assim, tera a tela inicial com uma leve animação no logo entrando e um som","sender":"5514997877554","ts":"2026-06-22T20:52:08Z","ts_label":"22/06 17:52","meta_prefix":"[22/06 17:52 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC99557EEA124830E4789C9C67AC0174","filename":"image_20260622_205222.jpg","message_id":"AC99557EEA124830E4789C9C67AC0174","sender":"5514997877554","ts":"2026-06-22T20:52:22Z","ts_label":"22/06 17:52","meta_prefix":"[22/06 17:52 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_205222.jpg]"},{"kind":"text","text":"Depois vai para a tela de módulos que tera todos os  módulos que serão estudados:","sender":"5514997877554","ts":"2026-06-22T20:52:56Z","ts_label":"22/06 17:52","meta_prefix":"[22/06 17:52 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_ACE168BA1C29C3528C656A29BA0CE325","filename":"image_20260622_205324.jpg","message_id":"ACE168BA1C29C3528C656A29BA0CE325","sender":"5514997877554","ts":"2026-06-22T20:53:24Z","ts_label":"22/06 17:53","meta_prefix":"[22/06 17:53 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_205324.jpg]"},{"kind":"attachment","slot_id":"slot_AC34EFA8F15451CB47A5A58E8D5D777F","filename":"image_20260622_205916.jpg","message_id":"AC34EFA8F15451CB47A5A58E8D5D777F","sender":"5514997877554","ts":"2026-06-22T20:59:16Z","ts_label":"22/06 17:59","meta_prefix":"[22/06 17:59 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_205916.jpg]"},{"kind":"text","text":"https://docs.google.com/document/d/1nMe50tPPn649qXet00aJz18DaJH_NSMC27Ze5mXtM2Y/edit?usp=drivesdk","sender":"5514997877554","ts":"2026-06-22T20:59:24Z","ts_label":"22/06 17:59","meta_prefix":"[22/06 17:59 ~5514997877554]"},{"kind":"text","text":"Siga esses módulos","sender":"5514997877554","ts":"2026-06-22T20:59:36Z","ts_label":"22/06 17:59","meta_prefix":"[22/06 17:59 ~5514997877554]"},{"kind":"text","text":"E no lado direito em cima é o botão de configuração, que da para mudar a musica etc","sender":"5514997877554","ts":"2026-06-22T21:00:23Z","ts_label":"22/06 18:00","meta_prefix":"[22/06 18:00 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_ACD3AD4E572221AE28565197FDEF1DFE","filename":"image_20260622_210036.jpg","message_id":"ACD3AD4E572221AE28565197FDEF1DFE","sender":"5514997877554","ts":"2026-06-22T21:00:36Z","ts_label":"22/06 18:00","meta_prefix":"[22/06 18:00 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_210036.jpg]"},{"kind":"text","text":"Ao clicar em um módulo vai para a tela das atividades do módulo:","sender":"5514997877554","ts":"2026-06-22T21:01:10Z","ts_label":"22/06 18:01","meta_prefix":"[22/06 18:01 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC3B6C154A136DA718338BB4B13C0D7E","filename":"image_20260622_210318.jpg","message_id":"AC3B6C154A136DA718338BB4B13C0D7E","sender":"5514997877554","ts":"2026-06-22T21:03:18Z","ts_label":"22/06 18:03","meta_prefix":"[22/06 18:03 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_210318.jpg]"},{"kind":"text","text":"A regra é simples com esseção do primeiro módulo todos os outros estarao bloqueados com um cadeado, o próximo modulo só é liberado quando todas as atividades do módulo anterior estiverem concluidas","sender":"5514997877554","ts":"2026-06-22T21:13:58Z","ts_label":"22/06 18:13","meta_prefix":"[22/06 18:13 ~5514997877554]"},{"kind":"text","text":"Assim que todas as lições do primeiro modulo forem concluidas o módula delas ficara amarelo e o cadeado da próxima ira sumir","sender":"5514997877554","ts":"2026-06-22T21:14:41Z","ts_label":"22/06 18:14","meta_prefix":"[22/06 18:14 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC2A2544B622B6667E296C6C4B5C6196","filename":"image_20260622_211457.jpg","message_id":"AC2A2544B622B6667E296C6C4B5C6196","sender":"5514997877554","ts":"2026-06-22T21:14:57Z","ts_label":"22/06 18:14","meta_prefix":"[22/06 18:14 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_211457.jpg]"},{"kind":"text","text":"As liçoes tem a mesma regra, a proxima só é liberada quando a anterior estiver completa, ai fica amarela e o cadiado da proxima some","sender":"5514997877554","ts":"2026-06-22T21:15:59Z","ts_label":"22/06 18:15","meta_prefix":"[22/06 18:15 ~5514997877554]"},{"kind":"text","text":"Mais tem uma regra a pessoa só conclui a lição quando acertar 100% da atividade","sender":"5514997877554","ts":"2026-06-22T21:16:37Z","ts_label":"22/06 18:16","meta_prefix":"[22/06 18:16 ~5514997877554]"},{"kind":"text","text":"O módulo tambem só é concluido quando todas as lições estiverem amarelo","sender":"5514997877554","ts":"2026-06-22T21:17:01Z","ts_label":"22/06 18:17","meta_prefix":"[22/06 18:17 ~5514997877554]"},{"kind":"text","text":"A tela das perguntas serao assim:","sender":"5514997877554","ts":"2026-06-22T21:17:27Z","ts_label":"22/06 18:17","meta_prefix":"[22/06 18:17 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC669423E31B294A4250326E9733DFC1","filename":"image_20260622_211747.jpg","message_id":"AC669423E31B294A4250326E9733DFC1","sender":"5514997877554","ts":"2026-06-22T21:17:47Z","ts_label":"22/06 18:17","meta_prefix":"[22/06 18:17 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_211747.jpg]"},{"kind":"text","text":"As perguntas aparecem dentro do quadro branco, a pessoa escreve a resposta no espaço de resposta roxo e o bunequinho fica variando","sender":"5514997877554","ts":"2026-06-22T21:28:11Z","ts_label":"22/06 18:28","meta_prefix":"[22/06 18:28 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_ACD2CDE49001E87A97AE2D2D9CE6C469","filename":"image_20260622_212830.jpg","message_id":"ACD2CDE49001E87A97AE2D2D9CE6C469","sender":"5514997877554","ts":"2026-06-22T21:28:30Z","ts_label":"22/06 18:28","meta_prefix":"[22/06 18:28 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_212830.jpg]"},{"kind":"text","text":"Se a pessoa tiver errado aparece essa aba com a resposta correta e o bonequinho falanfo errado se a pessoa quiser voltar para consertar a resposta ela pode se nao ela segue","sender":"5514997877554","ts":"2026-06-22T21:29:28Z","ts_label":"22/06 18:29","meta_prefix":"[22/06 18:29 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_ACD4CF4F259DC806E5BF05BCD55BFF3F","filename":"image_20260622_212941.jpg","message_id":"ACD4CF4F259DC806E5BF05BCD55BFF3F","sender":"5514997877554","ts":"2026-06-22T21:29:40Z","ts_label":"22/06 18:29","meta_prefix":"[22/06 18:29 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_212941.jpg]"},{"kind":"text","text":"Se ela acertar aparece assim, a resposta com o bonequinho certo","sender":"5514997877554","ts":"2026-06-22T21:30:00Z","ts_label":"22/06 18:30","meta_prefix":"[22/06 18:30 ~5514997877554]"},{"kind":"text","text":"E a opção de proceguir","sender":"5514997877554","ts":"2026-06-22T21:30:10Z","ts_label":"22/06 18:30","meta_prefix":"[22/06 18:30 ~5514997877554]"},{"kind":"text","text":"A IA tem que estar integrada para poder analizar se as respostas estao certas ou erradas e passar a resposta certa","sender":"5514997877554","ts":"2026-06-22T21:31:10Z","ts_label":"22/06 18:31","meta_prefix":"[22/06 18:31 ~5514997877554]"},{"kind":"text","text":"No final se a pessoa tiver acertado menos que 50% aparece essa tela","sender":"5514997877554","ts":"2026-06-22T21:31:41Z","ts_label":"22/06 18:31","meta_prefix":"[22/06 18:31 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC4C0A8E7EC9E534BA64C096C3D38683","filename":"image_20260622_213156.jpg","message_id":"AC4C0A8E7EC9E534BA64C096C3D38683","sender":"5514997877554","ts":"2026-06-22T21:31:56Z","ts_label":"22/06 18:31","meta_prefix":"[22/06 18:31 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_213156.jpg]"},{"kind":"text","text":"Com o bonequinho bem triste","sender":"5514997877554","ts":"2026-06-22T21:32:07Z","ts_label":"22/06 18:32","meta_prefix":"[22/06 18:32 ~5514997877554]"},{"kind":"text","text":"Se ela acertar mais que 50% aparece esse","sender":"5514997877554","ts":"2026-06-22T21:34:56Z","ts_label":"22/06 18:34","meta_prefix":"[22/06 18:34 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC392C61C0A00157EC8B29F92267A25B","filename":"image_20260622_213506.jpg","message_id":"AC392C61C0A00157EC8B29F92267A25B","sender":"5514997877554","ts":"2026-06-22T21:35:05Z","ts_label":"22/06 18:35","meta_prefix":"[22/06 18:35 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_213506.jpg]"},{"kind":"text","text":"E se ela acertar 100% aparece esse do uau","sender":"5514997877554","ts":"2026-06-22T21:35:21Z","ts_label":"22/06 18:35","meta_prefix":"[22/06 18:35 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_ACAC8A575B55A2D69C508FE0ADBC2AFA","filename":"image_20260622_213535.jpg","message_id":"ACAC8A575B55A2D69C508FE0ADBC2AFA","sender":"5514997877554","ts":"2026-06-22T21:35:35Z","ts_label":"22/06 18:35","meta_prefix":"[22/06 18:35 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_213535.jpg]"},{"kind":"text","text":"Lembrando que as próximas lições só sao liberadas quando a pessoa acerta 100% e conclui a atividade","sender":"5514997877554","ts":"2026-06-22T21:36:13Z","ts_label":"22/06 18:36","meta_prefix":"[22/06 18:36 ~5514997877554]"},{"kind":"text","text":"Quando a pessoa concluir todos os módulos aparece essa tela","sender":"5514997877554","ts":"2026-06-22T21:59:24Z","ts_label":"22/06 18:59","meta_prefix":"[22/06 18:59 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_ACB3F4C7238A32C7579658242EC48827","filename":"image_20260622_215940.jpg","message_id":"ACB3F4C7238A32C7579658242EC48827","sender":"5514997877554","ts":"2026-06-22T21:59:41Z","ts_label":"22/06 18:59","meta_prefix":"[22/06 18:59 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_215940.jpg]"},{"kind":"attachment","slot_id":"slot_AC9849E43CF8B10CE45468EF2D51C2A4","filename":"image_20260622_223032.jpg","message_id":"AC9849E43CF8B10CE45468EF2D51C2A4","sender":"5514997877554","ts":"2026-06-22T22:30:32Z","ts_label":"22/06 19:30","meta_prefix":"[22/06 19:30 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: image_20260622_223032.jpg]"},{"kind":"text","text":"Depois da tela de inicio aparece essa tela, tudo o que eu passei é do botão de Lições, agora vou passar do Quiz bíblico","sender":"5514997877554","ts":"2026-06-22T22:31:20Z","ts_label":"22/06 19:31","meta_prefix":"[22/06 19:31 ~5514997877554]"},{"kind":"text","text":"https://docs.google.com/document/d/1MqgnqjT3ALXY67atmYbdoEa7pxARIiTmjrs8uDix8nM/edit?usp=drivesdk","sender":"5514997877554","ts":"2026-06-23T03:04:11Z","ts_label":"23/06 00:04","meta_prefix":"[23/06 00:04 ~5514997877554]"},{"kind":"text","text":"Esse é o documento de como deve ser o app","sender":"5514997877554","ts":"2026-06-23T03:30:25Z","ts_label":"23/06 00:30","meta_prefix":"[23/06 00:30 ~5514997877554]"},{"kind":"text","text":"A seguir mandarei as perguntas de cada lição dentro de cada módulo:","sender":"5514997877554","ts":"2026-06-23T03:30:58Z","ts_label":"23/06 00:30","meta_prefix":"[23/06 00:30 ~5514997877554]"},{"kind":"attachment","slot_id":"slot_AC4948621AF77A28E1CEE094BBE6CDF1","filename":"1_a_10.xlsx","message_id":"AC4948621AF77A28E1CEE094BBE6CDF1","sender":"5514997877554","ts":"2026-06-23T03:31:07Z","ts_label":"23/06 00:31","meta_prefix":"[23/06 00:31 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: 1_a_10.xlsx]"},{"kind":"attachment","slot_id":"slot_AC4EFD3AF881813BA5B324701018CCDC","filename":"11_a_20.xlsx","message_id":"AC4EFD3AF881813BA5B324701018CCDC","sender":"5514997877554","ts":"2026-06-23T03:31:13Z","ts_label":"23/06 00:31","meta_prefix":"[23/06 00:31 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: 11_a_20.xlsx]"},{"kind":"attachment","slot_id":"slot_AC671EC869B160E91A254B25BD46333C","filename":"21_a_30.xlsx","message_id":"AC671EC869B160E91A254B25BD46333C","sender":"5514997877554","ts":"2026-06-23T03:32:19Z","ts_label":"23/06 00:32","meta_prefix":"[23/06 00:32 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: 21_a_30.xlsx]"},{"kind":"attachment","slot_id":"slot_AC60239D95BB96CB1A5BB9FC5770E044","filename":"31_a_40.xlsx","message_id":"AC60239D95BB96CB1A5BB9FC5770E044","sender":"5514997877554","ts":"2026-06-23T03:38:23Z","ts_label":"23/06 00:38","meta_prefix":"[23/06 00:38 ~5514997877554]","downloaded":true,"unavailable":false,"ref":"[anexo: 31_a_40.xlsx]"},{"kind":"text","text":"https://docs.google.com/document/d/1MqgnqjT3ALXY67atmYbdoEa7pxARIiTmjrs8uDix8nM/edit?usp=drivesdk","sender":"5514997877554","ts":"2026-06-23T04:12:59Z","ts_label":"23/06 01:12","meta_prefix":"[23/06 01:12 ~5514997877554]"},{"kind":"text","text":"Documento completo do APP","sender":"5514997877554","ts":"2026-06-23T04:13:11Z","ts_label":"23/06 01:13","meta_prefix":"[23/06 01:13 ~5514997877554]"}],"counts":{"text":47,"audio":0,"video":0,"attachment":21,"skipped":0,"unavailable":0},"missing_media":[],"chat_total_messages":68,"messages_read":68,"partial_history":fal