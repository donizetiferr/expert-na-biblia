{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "MINIMAX_API_KEY": "$MINIMAX_API_KEY",
        "OPENAI_API_KEY": "$OPENAI_API_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "MINIMAX_API_KEY": "$MINIMAX_API_KEY",
        "OPENAI_API_KEY": "$OPENAI_API_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
